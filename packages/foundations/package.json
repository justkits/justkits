{
  "name": "@justkits/design-foundations",
  "description": "JustKits Design System - Foundations",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "keywords": [
    "design tokens",
    "foundations",
    "react",
    "typescript"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "author": "JustWon",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/justkits/design-system.git"
  },
