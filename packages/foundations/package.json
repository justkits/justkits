    "registry": "https://npm.pkg.github.com/"
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@justkits/tsconfig": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "~5.9.3"
