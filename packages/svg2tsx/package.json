{
  "name": "@justkits/svg2tsx",
  "description": "JustKits SVG to TSX Converter Package",
  "version": "1.2.3",
  "private": false,
  "type": "module",
  "keywords": [
    "icons",
    "react",
    "typescript"
  ],
  "bin": {
    "svg2tsx": "./dist/cli/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "author": "JustWon",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/justkits/design-system.git",
    "directory": "packages/svg2tsx"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com/"
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:dev": "vitest --watch --coverage"
  },
  "devDependencies": {
    "tsup": "catalog:"
  },
  "dependencies": {
    "@svgr/core": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@svgr/plugin-svgo": "^8.1.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "jiti": "^2.6.1",
    "p-limit": "^7.3.0"
  },
  "lint-staged": {
    "*.{yml,yaml}": "prettier --check",
    "*.{js,mjs,cjs,ts,mts,cts,json,jsonc,json5,md,css,tsx,jsx}": [
      "eslint",
      "prettier --check"
    ]
  }
}
