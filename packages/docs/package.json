{
  "name": "@justkits/docs",
  "description": "JustKits Docs - Automated Sidebar Generation for Documentation Websites",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "keywords": [
    "documentation",
    "sidebar",
    "react",
    "typescript"
  ],
  "author": "JustWon",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/justkits/justkits.git",
    "directory": "packages/docs"
  },
  "license": "UNLICENSED",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com/"
  },
  "exports": {
    "./next": {
      "types": "./dist/next.d.mts",
      "default": "./dist/next.mjs"
    },
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "gray-matter": "^4.0.3"
  },
  "peerDependencies": {
    "next": "^16",
    "react": "^19",
    "react-dom": "^19"
  },
  "lint-staged": {
    "*": [
      "eslint",
      "prettier --check"
    ]
  }
}
