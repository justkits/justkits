{
  "name": "@justkits/buttons",
  "description": "JustKits Design System - Buttons",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "keywords": [
    "design",
    "system",
    "ui",
    "components",
    "buttons",
    "react",
    "typescript"
  ],
  "exports": {
    "./*": {
      "types": "./dist/*/index.d.mts",
      "default": "./dist/*/index.mjs"
    }
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@justkits/headless-ui": "workspace:*",
    "@justkits/tokens": "workspace:*",
    "@vanilla-extract/css": "catalog:",
    "@vanilla-extract/recipes": "catalog:",
    "clsx": "catalog:"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  }
}
