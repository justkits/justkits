{
  "name": "@justkits/ui",
  "description": "JustKits Design System",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "keywords": [
    "design-system",
    "tokens",
    "ui",
    "reset-css",
    "react",
    "typescript"
  ],
  "exports": {
    ".": {
      "types": "./dist/Provider.d.mts",
      "default": "./dist/Provider.mjs"
    },
    "./*": {
      "types": "./dist/*/index.d.mts",
      "default": "./dist/*/index.mjs"
    },
    "./tokens.css": {
      "types": "./dist/tokens.css.d.mts",
      "default": "./dist/tokens.css.mjs"
    },
    "./utils": {
      "types": "./dist/utils.d.mts",
      "default": "./dist/utils.mjs"
    }
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "icons": "svg2tsx && prettier --write ./src/atoms/Icons/ --log-level silent"
  },
  "devDependencies": {
    "@justkits/buttons": "workspace:*",
    "@justkits/headless-ui": "workspace:*",
    "@justkits/icons": "workspace:*",
    "@justkits/reset-css": "workspace:*",
    "@justkits/svg2tsx": "workspace:*",
    "@justkits/texts": "workspace:*",
    "@justkits/theme": "workspace:*",
    "@justkits/tokens": "workspace:*",
    "@vanilla-extract/css": "catalog:",
    "@vanilla-extract/dynamic": "^2.1.5",
    "@vanilla-extract/recipes": "catalog:",
    "@vanilla-extract/rollup-plugin": "catalog:",
    "clsx": "catalog:"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  }
}
