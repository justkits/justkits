{
  "name": "justkits-design-system",
  "version": "1.0.0",
  "packageManager": "pnpm@10.32.1",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "format": "prettier --write --log-level warn .",
    "lint": "eslint .",
    "test": "vitest run",
    "test:dev": "vitest run --watch --coverage",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "build": "turbo run build",
    "version": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@eslint/css": "^1.0.0",
    "@eslint/js": "^9.39.4",
    "@eslint/json": "^1.1.0",
    "@eslint/markdown": "^7.5.1",
    "@justkits/vitest-config": "workspace:*",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "*.{json,md,yml,yaml}": "prettier --check",
    "*.{ts,tsx,js,jsx}": [
      "prettier --check",
      "eslint"
    ]
  },
  "pnpm": {
    "overrides": {
      "flatted": "3.4.2"
    }
  }
}
