{
  "extends": "@justkits/tsconfig/nextjs.json",
  "compilerOptions": {
    "paths": {
      "@app/*": ["./src/01.app/*"],
      "@pages/*": ["./src/02.pages/*"],
      "@widgets/*": ["./src/03.widgets/*"],
      "@features/*": ["./src/04.features/*"],
      "@entities/*": ["./src/05.entities/*"],
      "@shared/*": ["./src/06.shared/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
