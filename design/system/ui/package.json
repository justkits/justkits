{
  "name": "@justkits/ui",
  "type": "module",
  "exports": {
    "./Icons": {
      "types": "./dist/icons/index.d.mts",
      "default": "./dist/icons/index.mjs"
    },
    "./*": {
      "types": "./dist/components/*/index.d.mts",
      "default": "./dist/components/*/index.mjs"
    },
    "./tokens.css": {
      "types": "./dist/tokens.css.d.mts",
      "default": "./dist/tokens.css.mjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "icons": "svg2tsx && prettier --write ./src/icons/ --log-level silent"
  },
  "devDependencies": {
    "@justkits/design-foundations": "workspace:*",
    "@justkits/headless-ui": "workspace:*",
    "@justkits/svg2tsx": "workspace:*",
    "@vanilla-extract/css": "^1.20.1",
    "@vanilla-extract/recipes": "^0.5.7",
    "@vanilla-extract/rollup-plugin": "^1.5.3",
    "clsx": "^2.1.1"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  }
}
