{
  "name": "@justkits/design-foundations",
  "description": "JustKits Design Primitives - Design Foundations",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "keywords": [
    "design",
    "tokens",
    "reset-css",
    "foundations",
    "react",
    "typescript"
  ],
  "exports": {
    "./*": {
      "types": "./dist/*/index.d.mts",
      "import": "./dist/*/index.mjs"
    },
    "./colors/scheme": {
      "types": "./dist/colors/scheme.d.mts",
      "import": "./dist/colors/scheme.mjs"
    },
    "./color-scheme.css": "./dist/color-scheme.css",
    "./reset.css": "./dist/reset.css"
  },
  "author": "JustWon",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/justkits/justkits.git",
    "directory": "design/primitives/foundations"
  },
  "license": "UNLICENSED",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com/"
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19"
  }
}
